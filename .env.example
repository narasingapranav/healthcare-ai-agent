# Copy this file to .env and fill in your values.

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=healthcare_agent

# Set this to true if you want live LLM responses in the chatbot.
USE_LLM=true
LLM_PROVIDER=groq

# Required for live chatbot responses when USE_LLM=true.
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=

# Optional LLM keys kept for future provider support.
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional Indian platform integrations.
ONE_MG_API_URL=
ONE_MG_API_KEY=
PRACTO_API_URL=
PRACTO_API_KEY=
AYURVEDA_API_URL=
AYURVEDA_API_KEY=

# Optional external service keys.
WEATHERSTACK_API_KEY=
EXCHANGERATE_API_KEY=
SERP_API_KEY=
